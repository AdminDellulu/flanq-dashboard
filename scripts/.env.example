# Flanq — Supabase edge-function secrets
# Copy this file to scripts/.env then fill in every value.
# The script `set-supabase-secrets.py` reads this file and uploads to Supabase.
# NEVER commit scripts/.env (already gitignored).

# ─── Brand identity (your choice, no external lookup) ─────────────────
BRAND_ID=flanq
BRAND_LABEL=FLANQ
ORDER_NUMBER_PREFIX=F-
DEFAULT_SHIPPING_COST=110.00

# ─── Shopify (Flanq admin → Settings → Apps → Develop apps) ───────────
# SHOPIFY_STORE_HANDLE: the bit before ".myshopify.com" in your store URL
SHOPIFY_STORE_HANDLE=
SHOPIFY_API_VERSION=2024-01
# SHOPIFY_ACCESS_TOKEN: custom app "Admin API access token" (shown once)
# Scopes: read_orders, read_products, read_fulfillments, read_customers, read_inventory
SHOPIFY_ACCESS_TOKEN=
# SHOPIFY_WEBHOOK_SECRET: Shopify admin → Settings → Notifications → "Webhook shared secret"
SHOPIFY_WEBHOOK_SECRET=

# ─── Meta Ads (Business Manager → System Users) ───────────────────────
# META_AD_ACCOUNT_ID: format act_XXXXXXXXXX (from Ads Manager URL)
META_AD_ACCOUNT_ID=
# META_ACCESS_TOKEN: System User token, scopes ads_read + business_management, never-expire
META_ACCESS_TOKEN=
META_GRAPH_API_VERSION=v21.0

# ─── Razorpay (dashboard.razorpay.com → Settings → API Keys) ──────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET: you set this when creating the webhook in Razorpay
RAZORPAY_WEBHOOK_SECRET=

# ─── Velocity Express ─────────────────────────────────────────────────
VELOCITY_USERNAME=
VELOCITY_PASSWORD=

# ─── iThink Logistics (my.ithinklogistics.com → API Settings) ─────────
ITL_ACCESS_TOKEN=
ITL_SECRET_KEY=

# ─── Slack alerts (optional — leave empty to disable) ─────────────────
# SLACK_BOT_TOKEN: api.slack.com → your bot app → OAuth & Permissions → Bot User OAuth Token
SLACK_BOT_TOKEN=
# Channel IDs (right-click channel in Slack → "Copy channel ID"), NOT names
SLACK_CHANNEL_ALERTS=
SLACK_CHANNEL_FINANCE=
